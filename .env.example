# ============================================================
# GameVision Tuner - 環境変数サンプル
# ============================================================
# このファイルをコピーして .env を作成し、値を入力してください。
# .env は Git にコミットされません（.gitignore に含まれています）。
# ============================================================

# Supabase（Dashboard → Project Settings → API → Project API keys）
# anon (public) の値をコピー
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Stripe（Dashboard → 商品カタログ → 商品 → 料金の Price ID）
# 月額 ¥300 と 年額 ¥2,880 の2つを作成して ID をコピー
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# Stripe Checkout 完了後のリダイレクト先（LP の URL）
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=
